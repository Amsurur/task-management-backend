# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.
# Validated at boot by src/config (Zod); invalid/missing values fail fast.

# Runtime: development | test | production
NODE_ENV=development

# HTTP server
HOST=0.0.0.0
PORT=3000

# Log level: fatal|error|warn|info|debug|trace|silent (optional; defaults by env)
LOG_LEVEL=debug

# PostgreSQL connection string (must start with postgres:// or postgresql://)
DATABASE_URL=postgresql://postgres:12345@localhost:5432/taskmgmt?schema=public

# JWT secrets — generate strong random values, e.g. `openssl rand -base64 48`
# Each must be at least 32 characters.
JWT_ACCESS_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string-32

# Token lifetimes (JWT duration syntax: 15m, 7d, or seconds).
# auth_tz.md §8: access ~3h, refresh ~30d (refresh delivered as an httpOnly cookie).
JWT_ACCESS_TTL=3h
JWT_REFRESH_TTL=30d

# ─── Session cookie (refresh token) ───────────────────────────────────────────
SESSION_COOKIE_NAME=refresh_token
# SESSION_COOKIE_DOMAIN=example.com          # omit to scope to the exact host
# SESSION_COOKIE_SECURE=true                 # defaults on outside development
SESSION_COOKIE_SAMESITE=lax                  # lax | strict | none

# Where OAuth/Telegram flows redirect the browser back to after login
FRONTEND_URL=http://localhost:5173

# ─── OAuth / Telegram providers (auth_tz.md §3, §4, §7) ───────────────────────
# Optional until each provider's flow is wired; required once enabled.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=

# ─── Email / SMTP (OTP codes, invites; auth_tz.md §6) ─────────────────────────
# Optional. With SMTP_HOST unset, dev/test logs emails to the console; production
# WITHOUT SMTP_HOST throws on send (so configure this before enabling email login
# in prod). Any SMTP provider works — examples: Resend, SendGrid, Mailgun.
#   Resend:   host smtp.resend.com   · user "resend" · pass = API key (re_...)
#   SendGrid: host smtp.sendgrid.net · user "apikey" · pass = API key (SG....)
#   Mailgun:  host smtp.mailgun.org  · user postmaster@… · pass = SMTP password
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465                # 587 for STARTTLS
# SMTP_SECURE=true             # true for port 465; false for STARTTLS (587)
# SMTP_USER=resend
# SMTP_PASS=
# From address on outgoing mail (must be a verified sender/domain in prod)
# MAIL_FROM="Task Management <no-reply@yourdomain>"

# CORS allowed origins: comma-separated list, or `*` for any
CORS_ORIGIN=*

# ─── Attachment storage ───────────────────────────────────────────────────────
# Driver: `local` (disk, dev/test default) or `s3` (S3-compatible: AWS S3 / MinIO)
STORAGE_DRIVER=local
# Lifetime of presigned upload/download URLs, in seconds (30–86400)
STORAGE_PRESIGN_TTL=900
# Public base URL the API is reachable at (used to build local storage URLs)
PUBLIC_BASE_URL=http://localhost:3000
# Max accepted upload size in bytes (default 25 MiB)
ATTACHMENT_MAX_BYTES=26214400

# local driver — directory bytes are written to (gitignored)
LOCAL_STORAGE_DIR=./uploads

# s3 driver — required only when STORAGE_DRIVER=s3.
# For MinIO (see docker-compose): S3_ENDPOINT=http://localhost:9000, path-style on.
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_BUCKET=attachments
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin
# S3_FORCE_PATH_STYLE=true
